  "research_basis": [
    {
      "title": "Explainable Patterns in Cryptocurrency Microstructure",
      "url": "https://arxiv.org/abs/2602.00776",
      "review_status": "preprint",
      "use": "Supports testing compact top-of-book, spread, order-flow, and trade-flow features at one-second resolution with chronological validation; no reported performance is imported."
