      "review_status": "published_in_journal_of_financial_econometrics",
      "use": "Supports order-flow imbalance and depth-conditioned pressure as short-horizon microstructure variables."
    },
    {
      "title": "The Micro-Price: A High Frequency Estimator of Future Prices",
      "url": "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=2970694",
      "review_status": "working_paper",
      "use": "Supports testing spread-and-imbalance-conditioned microprice features for short-horizon direction."
    },
    {
      "title": "Cross-Impact of Order Flow Imbalance in Equity Markets",
      "url": "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=3993561",
      "review_status": "published_in_quantitative_finance",
      "use": "Supports integrated and lagged order-flow imbalance as a forecasting hypothesis while warning that impact decays rapidly."
    },
    {
      "title": "Order Flow Imbalance and Price Dynamics in CME Ether Futures",
      "url": "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=6772279",
      "review_status": "recent_unreviewed_preprint",
      "use": "Provides a recent crypto-futures OFI hypothesis only; its performance, parameter search, market, and execution assumptions are not imported."
    },
    {
      "title": "LightGBM GPU Targets",
      "url": "https://lightgbm.readthedocs.io/en/latest/GPU-Targets.html",
      "review_status": "official_documentation",
      "use": "Supports vendor-agnostic OpenCL training on the AMD host with FP64 accumulation requested for reproducibility."
    }
  ],
  "limitations": [
    "This is a six-variant post-hoc screen on already-consumed BTCUSDT calibration dates and cannot establish out-of-sample profitability.",
    "The source has event-level best-bid-offer and trade archives transformed into one-second causal features; it does not contain a reconstructed full Level-2 queue.",
    "ETHUSDT and SOLUSDT are outside this bounded screen and require separately certified source corpora before cross-asset viability can be assessed.",
    "A passing variant may only justify freezing a new architecture for genuinely unseen chronological and cross-asset evaluation.",
    "LightGBM prediction uses its CPU library path even though training is required to use OpenCL FP64 accumulation."
  ],
