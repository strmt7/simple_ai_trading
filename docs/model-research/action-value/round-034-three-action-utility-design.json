  "research_basis": [
    {
      "title": "Trading via Selective Classification",
      "url": "https://arxiv.org/abs/2110.14914",
      "use": "Supports a ternary long, short, or abstain action space with confidence-based rejection and chronological evaluation."
    },
    {
      "title": "Utility-Weighted Forecasting and Calibration for Risk-Adjusted Decisions under Trading Frictions",
      "url": "https://arxiv.org/abs/2601.07852",
      "use": "Supports aligning forecast loss and calibration with bounded decision consequences under explicit frictions. Round 34 uses a capped regret multiplier and imports no empirical result."
    },
    {
      "title": "Price predictability in limit order book with deep learning model",
      "url": "https://arxiv.org/abs/2409.14157",
      "use": "Supports treating three-class price prediction as opportunity plus direction and emphasizes volume imbalance for directional information."
    },
    {
      "title": "Universal Features of Price Formation in Financial Markets",
      "url": "https://arxiv.org/abs/1803.06917",
      "use": "Supports normalized supply-demand representations and shared parameters; Round 34 enforces exact within-asset direction symmetry."
    },
    {
      "title": "The Probability of Backtest Overfitting",
      "url": "https://doi.org/10.2139/ssrn.2326253",
      "use": "Motivates the single-variant budget, frozen hyperparameters, nested chronological gates, and continued withholding of untouched dates."
    },
    {
      "title": "LightGBM Parameters",
      "url": "https://lightgbm.readthedocs.io/en/latest/Parameters.html",
      "use": "Defines the multiclass objective and OpenCL device controls used by the implementation; class weighting is implemented through explicit per-row weights and followed by calibration."
    }
  ],
  "limitations": [
    "This is a BTC-only consumed-data architecture test; it cannot establish a portfolio or cross-asset result.",
    "The official Binance Futures exact bookTicker archive spans 320 days, not multiple years.",
    "The available bookDepth archive is sampled aggregate depth rather than event-level queue data and was previously insufficient; Round 34 therefore does not claim maker-fill or queue-position realism.",
    "Decision-regret weighting changes the training distribution, so unweighted chronological multiclass calibration and strict ranked-tail gates are mandatory.",
    "A passing consumed-data result would justify only a separately frozen untouched test, never live or testnet trading authority.",
    "No leverage is modeled because leverage cannot create predictive edge and magnifies tail loss."
  ]
