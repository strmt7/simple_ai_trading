  "research_basis": [
    {
      "title": "Trading via Selective Classification",
      "url": "https://arxiv.org/abs/2110.14914",
      "use": "Supports a ternary long, short, or abstain action space and confidence-based rejection under walk-forward evaluation. Round 33 uses after-cost barrier profitability rather than raw price direction."
    },
    {
      "title": "Machine Learning-Based Bitcoin Trading Under Transaction Costs: Evidence From Walk-Forward Forecasting",
      "url": "https://arxiv.org/abs/2606.00060",
      "use": "Supports explicit cost-aware abstention and shows that prediction-to-action conversion can dominate model-family differences. Its hourly results are not imported as evidence."
    },
    {
      "title": "Explainable Patterns in Cryptocurrency Microstructure",
      "url": "https://arxiv.org/abs/2602.00776",
      "use": "Supports stationary top-of-book, order-flow, spread, and volatility features with purged chronological validation."
    },
    {
      "title": "Deep Order Flow Imbalance: Extracting Alpha at Multiple Horizons from the Limit Order Book",
      "url": "https://doi.org/10.1111/mafi.12413",
      "use": "Supports stationary order-flow representations and explicit horizon diagnostics; it does not validate this Binance target."
    },
    {
      "title": "Universal Features of Price Formation in Financial Markets",
      "url": "https://arxiv.org/abs/1803.06917",
      "use": "Supports normalized supply-demand representations and parameter sharing. Round 33 applies exact within-asset mirror constraints only."
    },
    {
      "title": "The Probability of Backtest Overfitting",
      "url": "https://doi.org/10.2139/ssrn.2326253",
      "use": "Motivates the one-variant budget, frozen parameters, chronological gates, and continued withholding of untouched dates."
    }
  ],
  "limitations": [
    "This is a BTC-only consumed-data architecture test; it cannot establish a portfolio or cross-asset result.",
    "The official Binance Futures exact bookTicker archive spans 320 days, not multiple years.",
    "Conditional direction was only weakly discriminable in Round 32; Round 33 must reject if the precommitted calibration gate is not met.",
    "A passing consumed-data result would justify only a separately frozen untouched test, never live or testnet trading authority.",
    "No leverage is modeled because leverage cannot create predictive edge and magnifies tail loss."
  ]
