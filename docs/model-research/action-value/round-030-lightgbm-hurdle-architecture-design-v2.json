  "research_basis": [
    {
      "title": "Strictly Proper Scoring Rules, Prediction, and Estimation",
      "url": "https://doi.org/10.1198/016214506000001437",
      "use": "Supports proper probability scoring and retained Brier diagnostics. Round 30 fits binary log-loss heads and bounded Platt calibration without treating probability fit as trading profitability."
    },
    {
      "title": "LightGBM: A Highly Efficient Gradient Boosting Decision Tree",
      "url": "https://papers.nips.cc/paper/2017/hash/6449f44a102fde848669bdd9eb6b76fa-Abstract.html",
      "use": "Motivates an efficient tabular tree challenger to the neural baseline. Its general benchmark speed and accuracy results do not establish a financial or after-cost edge."
    },
    {
      "title": "LightGBM Parameters",
      "url": "https://lightgbm.readthedocs.io/en/latest/Parameters.html",
      "use": "Defines the binary, L2 regression, quantile, OpenCL device, and double-precision accumulation controls used here. Documentation of an objective or backend is not evidence of predictive value."
    },
    {
      "title": "LightGBM GPU Tutorial",
      "url": "https://lightgbm.readthedocs.io/en/latest/GPU-Tutorial.html",
      "use": "Documents OpenCL GPU training on modern AMD and NVIDIA hardware and automatic or explicit device selection. Round 30 still records and verifies the actual local backend instead of assuming accelerator availability."
    },
    {
      "title": "Deep Limit Order Book Forecasting",
      "url": "https://arxiv.org/abs/2403.09267",
      "use": "Shows that high limit-order-book forecast quality need not imply actionable transactions. Round 30 therefore retains exact after-cost threshold traces and all abstention and drawdown gates."
    },
    {
      "title": "Machine Learning-Based Bitcoin Trading Under Transaction Costs: Evidence From Walk-Forward Forecasting",
      "url": "https://arxiv.org/abs/2606.00060",
      "use": "Recent non-peer-reviewed hourly BTC evidence finds naive forecast-to-trade conversion can fail after costs and reports tree boosting as descriptively stronger than neural alternatives without formal dominance. Its data resolution, execution abstraction, models, and reported returns are not imported as validation."
    },
    {
      "title": "Quantile and Probability Curves Without Crossing",
      "url": "https://doi.org/10.3982/ECTA7880",
      "use": "Supports monotone rearrangement when independently estimated conditional quantiles cross. Round 30 applies only pairwise q10/q90 ordering and makes no distributional calibration claim from that repair."
    },
    {
      "title": "Multi-Horizon Forecasting for Limit Order Books: Novel Deep Learning Approaches and Hardware Acceleration using Intelligent Processing Units",
      "url": "https://arxiv.org/abs/2105.10430",
      "use": "Provides limit-order-book-specific evidence that forecast behavior depends on horizon. It does not select this sealed 900-second target or validate the LightGBM architecture."
    }
  ],
