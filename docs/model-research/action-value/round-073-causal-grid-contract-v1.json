    "bbo_update_count",
    "mean_spread_bps",
    "maximum_spread_bps",
    "liquidation_snapshot_count",
    "liquidation_observed_quote_notional"
  ],
  "derived_semantics": {
    "aggressive_buy": "aggregate trade where buyer_is_maker is false",
    "aggressive_sell": "aggregate trade where buyer_is_maker is true",
    "order_flow_imbalance": "bid additions plus ask removals minus bid removals minus ask additions",
    "order_flow_normalizer": "max(contemporaneous bid quote depth plus ask quote depth for the exact retained band, 1e-12); outside-20 flow is never normalized because outside-20 depth is not retained in the typed state",
    "microprice": "ask times bid quantity plus bid times ask quantity divided by total top quantity",
    "distance_weighted_depth": "sum of level quote notional divided by one-based level rank",
    "depth_concentration": "Herfindahl sum of squared level quote-notional shares",
    "zero_trade_window": "buy sell signed and absolute quote flow and trade count are zero; buyer_taker_share is zero and trade count disambiguates zero activity from sell-only activity",
    "zero_bbo_update_window": "mid return realized variation and update count are zero; mean and maximum spread use the latest strictly prior BBO and update count disambiguates carried state from observed updates",
    "liquidation_zero": "snapshot count and observed notional are zero when no provider snapshot was observed in the window; this is not proof of zero liquidations",
    "displayed_removal": "anonymous displayed quantity reduction; execution, cancellation, manipulation, and participant identity remain unresolved"
  },
  "validity_contract": {
