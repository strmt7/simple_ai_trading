  "purpose": "Construct deterministic causal one-second BTCUSDT, ETHUSDT, and SOLUSDT feature grids from admitted exact-wire v8 segments without targets, actor labels, fabricated values, or future receipts.",
  "research_update": [
    {
      "source": "https://arxiv.org/abs/1011.6402",
      "authority": "peer-reviewed primary market-microstructure research",
      "adaptation": "Order-flow imbalance is retained by depth band and normalized by displayed depth; trade volume alone is not treated as sufficient."
    },
    {
      "source": "https://arxiv.org/abs/1602.00731",
      "authority": "peer-reviewed primary market-microstructure research",
      "adaptation": "Spread, depth, and order-flow intensity are retained as separate state and resiliency primitives around liquidity shocks."
    },
    {
      "source": "https://arxiv.org/abs/2603.24137",
      "authority": "primary 2026 market-microstructure research",
      "adaptation": "Fine-scale event timing, signed-flow persistence, and partial recovery are modeled explicitly; profitability remains sensitive to later execution assumptions."
    },
    {
      "source": "https://arxiv.org/abs/2607.09230",
      "authority": "primary 2026 crypto-futures research",
      "adaptation": "L2 liquidity state is the required lower layer; order flow may only receive credit for incremental value above the same state rows."
    },
    {
      "source": "https://www.cftc.gov/LawRegulation/FederalRegister/FinalRules/2013-12365.html",
      "authority": "official CFTC interpretive guidance",
      "adaptation": "Public aggregated L2 lacks participant intent and account context. Displayed removals remain anonymous flow, never a spoofing or manipulation label."
    }
  ],
