    "buyer_taker_share",
    "bid_added_quote_{levels_1_5|levels_6_10|levels_11_20|outside_20}",
    "bid_removed_quote_{levels_1_5|levels_6_10|levels_11_20|outside_20}",
    "ask_added_quote_{levels_1_5|levels_6_10|levels_11_20|outside_20}",
    "ask_removed_quote_{levels_1_5|levels_6_10|levels_11_20|outside_20}",
    "normalized_order_flow_imbalance_{levels_1_5|levels_6_10|levels_11_20}",
