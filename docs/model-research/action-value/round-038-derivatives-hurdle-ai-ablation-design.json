    "long_funding_cash_flow_bps": "-10000 * sum(last_funding_rate in holding window)",
    "short_funding_cash_flow_bps": "+10000 * sum(last_funding_rate in holding window)",
    "long_net_utility_bps": "10000 * (exit_open / entry_open - 1) - 12 + long_funding_cash_flow_bps",
    "short_net_utility_bps": "10000 * (1 - exit_open / entry_open) - 12 + short_funding_cash_flow_bps",
    "target_class": {
      "short": "short_net_utility_bps > 0 and short_net_utility_bps > long_net_utility_bps",
      "abstain": "max(long_net_utility_bps, short_net_utility_bps) <= 0",
      "long": "long_net_utility_bps > 0 and long_net_utility_bps >= short_net_utility_bps"
