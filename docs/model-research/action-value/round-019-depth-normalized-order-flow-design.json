  "research_basis": [
    {
      "title": "Strictly Proper Scoring Rules, Prediction, and Estimation",
      "url": "https://doi.org/10.1198/016214506000001437",
      "use": "Supports the retained unweighted binary log loss for truthful profitability probabilities. The separate ranking term remains explicitly non-proper, so Brier diagnostics continue to expose calibration damage."
    },
    {
      "title": "Deep Learning for Limit Order Books",
      "url": "https://arxiv.org/abs/1601.01987",
      "use": "Motivates modeling a conditional future distribution and inspecting its tails, while this experiment explicitly remains limited to observed best-bid/offer and trade features."
    },
    {
      "title": "DeepLOB: Deep Convolutional Neural Networks for Limit Order Books",
      "url": "https://arxiv.org/abs/1808.03668",
      "use": "Supports shared nonlinear representations for order-book prediction but does not establish an after-cost edge for this model or corpus."
    },
    {
      "title": "BDLOB: Bayesian Deep Convolutional Neural Networks for Limit Order Books",
      "url": "https://arxiv.org/abs/1811.10041",
      "use": "Motivates independent-seed dispersion and abstention when predictive uncertainty is high rather than forcing a trade."
    },
    {
      "title": "The Price Impact of Order Book Events",
      "url": "https://arxiv.org/abs/1011.6402",
      "use": "Finds that short-horizon price impact varies with order-flow imbalance and inversely with depth. Round 19 adds causal depth-normalized aggressive order-flow inputs based on opposing displayed L1 depth; profitability remains unproven."
    },
    {
      "title": "Order Flows and Limit Order Book Resiliency on the Meso-Scale",
      "url": "https://arxiv.org/abs/1708.02715",
      "use": "Supports combining active trade flow with passive depth and resiliency rather than treating directional trade imbalance as sufficient on its own."
    },
    {
      "title": "Deep Learning for Digital Asset Limit Order Books",
      "url": "https://arxiv.org/abs/2010.01241",
      "use": "Provides crypto-specific evidence that short-horizon order-book prediction is testable with walk-forward data, without implying execution profitability."
    },
    {
      "title": "Do Order-Book States Predict Passive-Buy Toxicity? Evidence from BTC Perpetual Futures",
      "url": "https://papers.ssrn.com/sol3/papers.cfm?abstract_id=6693260",
      "use": "Recent non-peer-reviewed BTC evidence motivates testing depth-normalized aggressive order flow, near-touch displayed liquidity, and liquidity fragility; its reported findings are not imported as validation."
    },
    {
      "title": "DirectML",
      "url": "https://microsoft.github.io/DirectML/PyTorch.html",
      "use": "Defines the vendor-neutral DirectX 12 training path used in a clean process on this AMD host; CPU fallback remains forbidden for this experiment."
    }
  ],
